@dns = k8s.orb.local
@host = http://tokenization-service.{{dns}}
@realm = dev

###################################################
### Auth - well-known
###################################################
# @name well_known
GET http://keycloak.{{dns}}/realms/{{realm}}/.well-known/openid-configuration

###################################################
### Auth - access_token
###################################################
# @name auth
POST {{well_known.response.body.token_endpoint}}
Content-Type: application/x-www-form-urlencoded

grant_type=password
&client_id=rest-client
&client_secret=ZoxeWS2LdJEtilfoTxLvJtOnhsnGIQQT
&username=john.doe
&password=John123
&scope=openid tokenizer.write

### access_token
@access_token = {{auth.response.body.access_token}}

###################################################
### Tokenization - health
###################################################
GET {{host}}/actuator/health
Accept: application/json

###################################################
### Tokenization - Visa Crédito (BIN 411111 - Banco do Brasil)
###################################################
POST {{host}}/v1/card/tokenize
Content-Type: application/json
Accept: application/json
Authorization: Bearer {{access_token}}

{
  "card_number": "4111111111111111",
  "holder_name": "JOSE DA SILVA",
  "expiration_month": 12,
  "expiration_year": 2028,
  "cvv": "123"
}

